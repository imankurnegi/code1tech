{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true, // <--- Yeh sabse zaroori hai JSON imports ke liye
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Strictness & Checks */
    "strict": false, // Aapne strictness kam rakhi hai toh wahi rehne diya
    "allowJs": true,
    "esModuleInterop": true, // <--- CommonJS modules (node-fetch) ke liye zaroori hai
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src", "scripts/prefetch.js"], // <--- Prefetch script ko bhi include kar lo
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}